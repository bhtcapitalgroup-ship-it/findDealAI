# RealDeal AI — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://realdeal:realdeal@localhost:5432/realdeal

# Redis
REDIS_URL=redis://localhost:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-...

# External Data APIs
RENTCAST_API_KEY=          # https://www.rentcast.io — $50/mo for 500 calls
CENSUS_API_KEY=            # https://api.census.gov/data/key_signup.html (free, optional)
GREATSCHOOLS_API_KEY=      # https://www.greatschools.org/api/ (free with approval)

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Stripe (optional for MVP)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
