# ===========================================================================
# RealDeal AI — Backend Environment Variables
# Copy to .env and fill in real values before running.
# ===========================================================================

# ── Application ───────────────────────────────────────────────────────────
APP_NAME=RealDeal AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Database (PostgreSQL + asyncpg) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://realdeal:realdeal@localhost:5432/realdeal

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth / JWT ────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-use-a-64-char-random-string-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI / LLM ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── External Data APIs ───────────────────────────────────────────────────
RENTCAST_API_KEY=CHANGE_ME                # https://www.rentcast.io
CENSUS_API_KEY=CHANGE_ME                  # https://api.census.gov/data/key_signup.html (free)
GREATSCHOOLS_API_KEY=CHANGE_ME            # https://www.greatschools.org/api/

# ── Twilio (SMS alerts) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1CHANGE_ME

# ── Plaid (ACH payments) ─────────────────────────────────────────────────
PLAID_CLIENT_ID=CHANGE_ME
PLAID_SECRET=CHANGE_ME
PLAID_ENV=sandbox

# ── AWS S3 (document storage) ────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=realdeal-documents
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ── Stripe (payments & subscriptions) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","chrome-extension://*"]

# ── Rate Limits (requests per day by tier) ────────────────────────────────
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_PRO_PLUS=1000
