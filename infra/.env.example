# =============================================================================
# RealDeal AI — Environment Variables
# Copy to .env and fill in real values before running docker-compose.
#
# COST: This entire stack runs for $0/month on free tiers.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# -----------------------------------------------------------------------------
# PostgreSQL  [FREE: local Docker or Neon free tier]
# -----------------------------------------------------------------------------
POSTGRES_USER=realdeal
POSTGRES_PASSWORD=realdeal
POSTGRES_DB=realdeal
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# For local Docker (default):
DATABASE_URL=postgresql+asyncpg://realdeal:realdeal@postgres:5432/realdeal

# For Neon free tier (500MB, 0.25 vCPU -- FREE):
# Sign up at https://neon.tech -> Create project -> Copy connection string
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/realdeal?sslmode=require

# -----------------------------------------------------------------------------
# Redis  [FREE: local Docker or Upstash free tier]
# -----------------------------------------------------------------------------
REDIS_PASSWORD=changeme

# For local Docker (default):
REDIS_URL=redis://:changeme@redis:6379/0

# For Upstash free tier (10K commands/day, 256MB -- FREE):
# Sign up at https://upstash.com -> Create database -> Copy connection string
# REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

CELERY_BROKER_URL=redis://:changeme@redis:6379/1
CELERY_RESULT_BACKEND=redis://:changeme@redis:6379/2

# -----------------------------------------------------------------------------
# Backend / FastAPI
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Maps: Uses Leaflet + OpenStreetMap (FREE, no API key needed!)
# No MAPBOX_TOKEN required.

# -----------------------------------------------------------------------------
# Nginx (optional)
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# AI / LLM  [FREE: template-based analysis by default, no API key needed]
# -----------------------------------------------------------------------------
# The app works perfectly WITHOUT any LLM -- all analysis is math-based
# with template-generated summaries.
#
# OPTIONAL: For richer AI-generated text, run Ollama locally (free):
#   docker compose --profile with-ollama up
#   docker exec realdeal-ollama ollama pull llama3
# Then uncomment:
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Scraping  [FREE: direct HTTP requests, no paid proxy service]
# -----------------------------------------------------------------------------
# The scraper uses direct HTTP with User-Agent rotation and rate limiting.
# No BrightData or paid proxy needed!
#
# OPTIONAL: Add free proxy URLs for extra IP rotation (comma-separated):
# FREE_PROXY_LIST=http://proxy1:port,http://proxy2:port

# -----------------------------------------------------------------------------
# Email  [FREE: SendGrid free tier or Gmail SMTP]
# -----------------------------------------------------------------------------
# Option 1: SendGrid free tier (100 emails/day -- FREE)
# Sign up at https://sendgrid.com -> Create API key
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Option 2: Gmail SMTP (FREE, unlimited for personal use)
# Enable 2FA on Gmail -> Create App Password at https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your.email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password

# If neither is set, emails are logged to console (dev mode).
NOTIFICATION_FROM_EMAIL=alerts@realdeal-ai.com
NOTIFICATION_FROM_NAME=RealDeal AI

# -----------------------------------------------------------------------------
# External Data APIs (optional, for Chrome Extension)
# -----------------------------------------------------------------------------
# RENTCAST_API_KEY=          # Has free tier
# CENSUS_API_KEY=            # FREE -- census.gov keys are free
# GREATSCHOOLS_API_KEY=      # Has free tier

# -----------------------------------------------------------------------------
# Payments (optional -- only needed if accepting payments)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------------------------------------------
# Sentry (optional -- free tier: 5K errors/month)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1
