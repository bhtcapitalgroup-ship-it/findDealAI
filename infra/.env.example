# =============================================================================
# RealDeal AI — Environment Variables
# Copy to .env and fill in real values before running docker-compose.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=realdeal
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=realdeal
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# -----------------------------------------------------------------------------
# Backend / FastAPI
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:80
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Frontend / Next.js
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.CHANGE_ME_MAPBOX_PUBLIC_TOKEN

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# Third-Party: Proxy / Scraping
# -----------------------------------------------------------------------------
BRIGHTDATA_ZONE=residential
BRIGHTDATA_HOST=brd.superproxy.io
BRIGHTDATA_PORT=22225
BRIGHTDATA_USERNAME=brd-customer-CHANGE_ME
BRIGHTDATA_PASSWORD=CHANGE_ME_BRIGHTDATA

# -----------------------------------------------------------------------------
# Third-Party: AI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_ANTHROPIC
AI_MODEL=gpt-4o
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Third-Party: Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.CHANGE_ME_SENDGRID
SENDGRID_FROM_EMAIL=alerts@realdeal-ai.com
SENDGRID_FROM_NAME=RealDeal AI

# -----------------------------------------------------------------------------
# Third-Party: Maps
# -----------------------------------------------------------------------------
MAPBOX_SECRET_TOKEN=sk.CHANGE_ME_MAPBOX_SECRET

# -----------------------------------------------------------------------------
# Third-Party: Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_CHANGE_ME_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_STRIPE

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
